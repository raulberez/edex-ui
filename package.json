{
  "name": "edex-ui",
  "version": "2.2.8",
  "description": "A fullscreen, cross-platform terminal emulator and system monitor that looks and feels like a sci-fi computer interface",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build",
    "build:linux": "electron-builder build --linux",
    "build:mac": "electron-builder build --mac",
    "build:win": "electron-builder build --win",
    "lint": "eslint src/",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GitSquared/edex-ui.git"
  },
  "keywords": [
    "terminal",
    "electron",
    "sci-fi",
    "system-monitor",
    "cross-platform"
  ],
  "author": "Gabriel Saillard <gabriel@saillard.dev>",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/GitSquared/edex-ui/issues"
  },
  "homepage": "https://github.com/GitSquared/edex-ui",
  "dependencies": {
    "node-pty": "^0.10.1",
    "systeminformation": "^5.11.9",
    "xterm": "^4.18.0",
    "xterm-addon-fit": "^0.5.0",
    "xterm-addon-web-links": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^17.4.0",
    "electron-builder": "^23.0.3",
    "eslint": "^8.13.0"
  },
  "build": {
    "appId": "com.gabrielsaillard.edexui",
    "productName": "eDEX-UI",
    "copyright": "Copyright © 2018-2022 Gabriel Saillard",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
